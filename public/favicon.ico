<script>
(function() {
  'use strict';

  function animerCompteurs() {
    var compteurs = document.querySelectorAll('[data-target]');
    var duree = 1200; // 800ms PRÉCIS

    compteurs.forEach(function(compteur) {
      var cible = parseFloat(compteur.dataset.target);
      var suffix = compteur.dataset.suffix || '';
      var isDecimal = cible % 1 !== 0;
      var debut = null;

      function updateCompteur(timestamp) {
        if (!debut) debut = timestamp;

        var elapsed = timestamp - debut;
        var progress = Math.min(elapsed / duree, 1);
        var valeurActuelle = progress * cible;

        if (progress < 1) {
          var display = isDecimal ? valeurActuelle.toFixed(1) : Math.floor(valeurActuelle);
          compteur.textContent = display + suffix;
          requestAnimationFrame(updateCompteur);
        } else {
          var finalDisplay = isDecimal ? cible.toFixed(1) : cible;
          compteur.textContent = finalDisplay + suffix;
        }
      }

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            requestAnimationFrame(updateCompteur);
            observer.unobserve(compteur);
          }
        });
      }, { threshold: 0.3 });

      observer.observe(compteur);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', animerCompteurs);
  } else {
    animerCompteurs();
  }

})();
</script></head><body><div data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner" class="navbar-logo-center-container shadow-tree w-nav"><div class="container-16"><div class="navbar-wrapper-three"><a href="/" class="navbar-brand-three w-nav-brand"><img width="Auto" loading="lazy" alt="WeFiiT - Cabinet Conseil Product Management" src="https://cdn.prod.website-files.com/63d687e3cca00b36190024ea/6710c9a846e54f6b5265ccd1_logo-wefiit-header.avif" class="image-44"/></a><nav role="navigation" class="nav-menu-wrapper-three w-nav-menu"><div class="nav-menu-three"><ul role="list" class="nav-menu-block w-list-unstyled"><li><div data-delay="0" data-hover="true" class="nav-dropdown-3 w-dropdown"><div class="nav-dropdown-toggle-4 w-dropdown-toggle"><div class="nav-dropdown-icon-3 w-icon-dropdown-toggle"></div><div class="text-block-37">Offres</div></div><nav class="nav-dropdown-list-2 shadow-three mobile-shadow-hide w-dropdown-list"><a href="/product-management" class="nav-dropdown-link w-dropdown-link">Product Management</a><a href="/product-ia-data-management" class="nav-dropdown-link w-dropdown-link">Product Data &amp; IA</a><a href="/product-marketing" class="nav-dropdown-link w-dropdown-link">Product Marketing</a><a href="/product-quality" class="nav-dropdown-link w-dropdown-link">Product Quality</a><a href="/product-ops" class="nav-dropdown-link w-dropdown-link">Product Ops</a></nav></div></li><li><a href="/cas-clients" class="nav-link-3">Cas clients</a></li><li><a href="/formation-product-management" class="nav-link-3">Formation</a></li><li><div data-delay="0" data-hover="true" class="nav-dropdown-3 w-dropdown"><div class="nav-dropdown-toggle-4 w-dropdown-toggle"><div class="nav-dropdown-icon-3 w-icon-dropdown-toggle"></div><div class="text-block-37">Médias</div></div><nav class="nav-dropdown-list-2 shadow-three mobile-shadow-hide w-dropdown-list"><a href="/we-talk" class="nav-dropdown-link w-dropdown-link">